# ─── Ma'lumotlar bazasi ───────────────────────────────────────────────────────
# PostgreSQL ulanish URL'i
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:STRONG_PASSWORD_HERE@localhost:5432/clinic_cms"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Production URL (masalan: https://klinika.uz)
NEXTAUTH_URL="http://localhost:3000"

# Kuchli, tasodifiy secret (kamida 32 belgi)
# Yaratish: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="CHANGE_THIS_TO_A_RANDOM_SECRET_AT_LEAST_32_CHARS"

# ─── Telegram Bot ────────────────────────────────────────────────────────────
# BotFather dan olingan token (@BotFather → /newbot)
TELEGRAM_BOT_TOKEN=""

# Telegram webhook uchun secret (ixtiyoriy, lekin tavsiya etiladi)
# Yaratish: openssl rand -hex 20
TELEGRAM_WEBHOOK_SECRET=""

# ─── CMS API (Telegram bot uchun) ────────────────────────────────────────────
CMS_API_URL="http://localhost:3000"
